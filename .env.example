# ====================================================================
# AstroDorado v3 — Variables de entorno
# Copia este archivo como .env.local (NO lo subas a git)
# ====================================================================

# ── Supabase (cliente y server) ─────────────────────────────────────
# URL del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://bpazmmbjjducdmxgfoum.supabase.co

# Anon key (pública, segura para cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role (SOLO server-side, NUNCA en cliente)
# Úsala solo en API routes y Server Actions sensibles
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Revalidación on-demand de ISR ───────────────────────────────────
# Token secreto para /api/revalidate (generar con openssl rand -hex 32)
REVALIDATE_TOKEN=cambiar-este-valor

# ── Integraciones futuras (sprint 2+) ───────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# ANTHROPIC_API_KEY=
